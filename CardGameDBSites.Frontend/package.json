    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-chartjs": "^5.3.3",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@nuxtjs/eslint-module": "^4.1.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
