{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "~/*": ["../app/*"]
    }
  },
  "include": ["./**/*.ts", "../app/helpers/**/*.ts", "../app/services/**/*.ts", "../app/components/**/*.ts", "../app/api/**/*.ts", "../app/models/**/*.ts"]
}
